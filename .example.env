# ==============================================================================
# AI Video & Meeting Assistant - Environment Configuration Template
# Duplicate this file, rename it to '.env', and fill in your actual API keys.
# ==============================================================================

# OpenAI API Configuration (Required for GPT models & Cloud Embeddings)
OPENAI_API_KEY=your_openai_api_key_here

# Groq Cloud API Configuration (Required for fast Cloud STT Transcription)
GROQ_API_KEY=your_groq_api_key_here

# Sarvam AI API Configuration (Required for multi-lingual Hinglish processing)
SARVAM_API_KEY=your_sarvam_api_key_here

# Local Whisper Engine Configuration (Used for Local CPU Mode processing)
# Options: tiny, base, small, medium, large
WHISPER_MODEL=tiny